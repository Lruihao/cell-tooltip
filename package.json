{
  "name": "cell-tooltip",
  "version": "0.1.2",
  "packageManager": "pnpm@10.30.3",
  "description": "A lightweight, dependency-free tooltip library inspired by Bootstrap's interaction model.",
  "author": "Lruihao (https://github.com/Lruihao)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Lruihao/cell-tooltip.git"
  },
  "keywords": [
    "tooltip",
    "cell-tooltip",
    "typescript",
    "javascript",
    "ui",
    "frontend",
    "dom",
    "lightweight",
    "bootstrap-inspired"
  ],
  "type": "module",
  "main": "./dist/cell-tooltip.umd.cjs",
  "module": "./dist/cell-tooltip.js",
  "types": "./dist/types/index.d.ts",
  "sideEffects": [
    "*.css"
  ],
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/cell-tooltip.js",
      "require": "./dist/cell-tooltip.umd.cjs"
    },
    "./style.css": "./dist/cell-tooltip.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build --config vite.lib.config.ts && tsc -p tsconfig.lib.json",
    "build:demo": "tsc && vite build --base /cell-tooltip/ --outDir dist-demo",
    "preview": "vite preview --outDir dist-demo"
  },
  "devDependencies": {
    "typescript": "~5.9.3",
    "vite": "^7.3.1"
  }
}
